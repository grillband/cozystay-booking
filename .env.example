# ─── Channel Manager API ──────────────────────────────────────────────────────
# When CHANNEL_MANAGER_API_KEY and CHANNEL_MANAGER_API_URL are both set,
# the app connects to the real channel manager API.
# When unset, built-in mock data is used for local development.

CHANNEL_MANAGER_API_KEY=
CHANNEL_MANAGER_API_URL=
CHANNEL_MANAGER_PROPERTY_ID=

# ─── Currency Exchange API ────────────────────────────────────────────────────
# Sign up at https://www.exchangerate-api.com/ for a free API key.
# When set, live exchange rates are fetched (cached for 1 hour).
# When unset, hardcoded approximate rates are used as fallback.

EXCHANGE_RATE_API_KEY=
